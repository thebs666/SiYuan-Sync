:"20251124180744-3s4w2zk","Type":"NodeParagraph","Properties":{"id":"20251124180744-3s4w2zk","updated":"20251124181926"},"Children":[{"Type":"NodeText","Data":"车机隐私协议可能不是最新的，要更新到最新版本的隐私协议——没问题"}]}]},{"ID":"20251124180758-6k21stj","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"NS4=","Num":5},"Properties":{"id":"20251124180758-6k21stj","updated":"20251124180758"},"Children":[{"ID":"20251124180758-1qgc6a4","Type":"NodeParagraph","Properties":{"id":"20251124180758-1qgc6a4","updated":"20251124180758"}}]}]},{"ID":"20251124180755-5e807qo","Type":"NodeParagraph","Properties":{"id":"20251124180755-5e807qo","updated":"20251124182933"},"Children":[{"Type":"NodeText","Data":"用户隐私协议的授权无法进行撤回——确实存在，暂时保持现状，但是潜在风险"}]},{"ID":"20251124180804-jylw9lp","Type":"NodeParagraph","Properties":{"id":"20251124180804-jylw9lp","updated":"20251125104529"},"Children":[{"Type":"NodeText","Data":"HUAWEI HiCar和ICCOA Carlink均有单独的授权开关，Apple Carplay没有，Carplay理论上不仅仅是扩展操作和投屏，会调用到麦克风和位置权限，所以这块也要单独做一个授权开关——需整改"}]},{"ID":"20251124194910-cbm2y0c","Type":"NodeParagraph","Properties":{"id":"20251124194910-cbm2y0c","updated":"20251124194910"}}]}