{"ID":"20251124180743-0crq8bh","Spec":"1","Type":"NodeDocument","Properties":{"id":"20251124180743-0crq8bh","title":"44496整改项","type":"doc","updated":"20251125104529"},"Children":[{"ID":"20251124180744-j8vxpit","Type":"NodeParagraph","Properties":{"id":"20251124180744-j8vxpit","updated":"20251124180744"},"Children":[{"Type":"NodeText","Data":"座舱授权功能相关："}]},{"ID":"20251124180744-ppfngyu","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20251124180744-ppfngyu","updated":"20251124182606"},"Children":[{"ID":"20251124180744-67yulao","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20251124180744-67yulao","updated":"20251124182538"},"Children":[{"ID":"20251124180744-jyswlww","Type":"NodeParagraph","Properties":{"id":"20251124180744-jyswlww","updated":"20251124182538"},"Children":[{"Type":"NodeText","Data":"行车记录仪无用户授权就能直接使用——"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"授权需要跟账号，并且能撤回授权(隐私管理需要增加开关)"}]}]},{"ID":"20251124180744-q339sdm","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Mi4=","Num":2},"Properties":{"id":"20251124180744-q339sdm","updated":"20251124182606"},"Children":[{"ID":"20251124180744-ic9pd27","Type":"NodeParagraph","Properties":{"id":"20251124180744-ic9pd27","updated":"20251124182606"},"Children":[{"Type":"NodeText","Data":"IM Audio没有授权麦克风就能直接使用——"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"@青怡 涉及应用更改，新开aone，1126外审；@mia 涉及新开aone，新增开关，1126外审"}]}]}]},{"ID":"20251124180744-pw0137y","Type":"NodeParagraph","Properties":{"id":"20251124180744-pw0137y","updated":"20251124180744"},"Children":[{"Type":"NodeText","Data":"隐私协议中未体现的功能："}]},{"ID":"20251124180744-0v8ma27","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20251124180744-0v8ma27","updated":"20251124182700"},"Children":[{"ID":"20251124180744-h223art","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20251124180744