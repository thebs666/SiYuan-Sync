0918前重新生成罐装包（此问题不能通过52包刷新，因为对应分区不在刷写范围）"}]}]},{"ID":"20250911112448-1fit8fc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250911112448-1fit8fc","updated":"20250911123706"},"Children":[{"ID":"20250911112448-cvrbalm","Type":"NodeParagraph","Properties":{"id":"20250911112448-cvrbalm","updated":"20250911123706"},"Children":[{"Type":"NodeText","Data":"方案2：P造车直接使用SOP第一轮评审版本，0923评审冻结，0924提供罐装包，工业化周期极为紧张"}]}]}]}]}]}]}]},{"ID":"20250911105526-w4ixvnx","Type":"NodeVideo","Data":"\u003cvideo controls=\"controls\" src=\"assets/飞书20250911-105453-20250911105526-azvuwq8.mp4\" data-src=\"assets/飞书20250911-105453-20250911105526-azvuwq8.mp4\"\u003e\u003c/video\u003e","Properties":{"id":"20250911105526-w4ixvnx","updated":"20250911105526"}},{"ID":"20250911113020-pt1lny6","Type":"NodeParagraph","Properties":{"id":"20250911113020-pt1lny6","updated":"20250911113020"}},{"ID":"20250911201932-93vpt10","Type":"NodeList","ListData":{},"Properties":{"id":"20250911201932-93vpt10","updated":"20250911202137"},"Children":[{"ID":"20250911202002-7vottld","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250911202002-7vottld","updated":"20250911202137"},"Children":[{"ID":"20250911202002-4okkdfr","Type":"NodeParagraph","Properties":{"id":"20250911202002-4okkdfr","updated":"20250911202002"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"P基线0828版本支持Pre-P造车，语音球必现置灰，语音功能无法使用，且OTA无法恢复"}]},{"ID":"20250911202004-jf0g816","Type":"NodeList","ListData":{},"Properties":{"id":"20250911202004-jf0g816","updated":"20250911202137"},"Children":[{"ID":"20250911202004-it0zlpq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20250911202004-it0zlpq","updated":"20250911202137"},"Children":[{"ID":"20250911202004-jq0bnuj","Type":"NodeParagraph","Properties":{"id":"20250911202004-jq0bnuj","updated":"20250911202137"},"Children":[{"Type":"NodeText","Data":"​"},{"Type":"NodeI